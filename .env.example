# Database (SQLite — path to your local db file)
DATABASE_URL="file:./dev.db"

# Admin dashboard password
ADMIN_PASSWORD="change-me-in-production"

# Resend API key (get yours free at resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email address that confirmation emails come FROM (must be a verified Resend sender)
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Your business name shown in emails
BUSINESS_NAME="AutoCash Buyers"

# Optional: your reply-to address for the auto-response
REPLY_TO_EMAIL="offers@yourdomain.com"
